{
  "name": "mcp-mysql-query",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP server: query MySQL (describe table + select data) with safe parameterization.",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:delete": "pm2 delete ecosystem.config.cjs",
    "pm2:status": "pm2 status",
    "pm2:logs": "pm2 logs mcp-mysql-query --lines 200"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.0",
    "mysql2": "^3.14.3",
    "pm2": "^6.0.14",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}

